                <mxCell id="lane_obs" value="&lt;b&gt;&amp;nbsp; &amp;nbsp;&lt;/b&gt;&lt;div&gt;&lt;b&gt;&amp;nbsp; &amp;nbsp;观测波形处理&lt;/b&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;dashed=1;fillColor=#F7FBFD;strokeColor=#B7D6E5;fontSize=16;fontStyle=1;fontColor=#1F6F8B;fontFamily=Microsoft YaHei;align=left;verticalAlign=top;spacing=10;connectable=0;" parent="1" vertex="1">
                    <mxGeometry x="96" y="585" width="300" height="564" as="geometry"/>
                </mxCell>
                <mxCell id="Hze-wx0C-8RTzvK5wBM4-8" value="&lt;b&gt;CAP 分窗与评分&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;dashed=1;fillColor=#FFF9F2;strokeColor=#E5C589;fontSize=16;fontStyle=1;fontColor=#8A4B1F;fontFamily=Microsoft YaHei;align=left;verticalAlign=top;spacing=10;connectable=0;" parent="1" vertex="1">
                    <mxGeometry x="598" y="858" width="562" height="386" as="geometry"/>
                </mxCell>
                <mxCell id="title" value="&lt;b data-index-in-node=&quot;0&quot; data-path-to-node=&quot;12,0,0&quot;&gt;CAP 波形反演流程&lt;/b&gt; (Cut-And-Paste Waveform Inversion)" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1;fontColor=#20242A;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;" parent="1" vertex="1">
                    <mxGeometry x="29" y="38" width="1430" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="obs" value="&lt;b&gt;观测数据&lt;/b&gt;&lt;br&gt;12 台站 × 3 分量位移记录" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8F3F8;strokeColor=#1F6F8B;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="131" y="659" width="230" height="82" as="geometry"/>
                </mxCell>
                <mxCell id="readObs" value="&lt;b&gt;读取观测波形&lt;/b&gt;&lt;br&gt;读取 SAC 头段与数据&lt;br&gt;提取 dist / az / 分量方向&lt;br&gt;检查台站方位覆盖" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8F3F8;strokeColor=#1F6F8B;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="116" y="814" width="260" height="118" as="geometry"/>
                </mxCell>
                <mxCell id="filterObs" value="&lt;b&gt;低频滤波&lt;/b&gt;&lt;br&gt;0.02–0.1 Hz 长周期带通&lt;br&gt;重采样至 1 s" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFF7E6;strokeColor=#8A6F2A;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="116" y="1004" width="260" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="fixed" value="&lt;b&gt;固定量与参考模型&lt;/b&gt;&lt;br&gt;固定：震中位置、一维速度模型、Mw = 4.79&lt;br&gt;震源时间函数：syn -D0.5（0.5 s 简单三角形）&lt;br&gt;参考机制：Z=12 km，φ=330°，δ=80°，λ=-15°" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#F1F5EA;strokeColor=#5D7A3B;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="630" y="191" width="505" height="109" as="geometry"/>
                </mxCell>
                <mxCell id="green" value="&lt;b&gt;按候选深度 Z&lt;/b&gt;&lt;br&gt;调用 FK 计算各台站 Green 函数&lt;br&gt;同一深度可复用" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EAF4FF;strokeColor=#2F6EA3;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="722.5" y="464" width="320" height="90" as="geometry"/>
                </mxCell>
                <mxCell id="syn" value="&lt;b&gt;按候选机制 φ / δ / λ&lt;/b&gt;&lt;br&gt;调用 syn 合成理论 Z/R/T 波形" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EAF4FF;strokeColor=#2F6EA3;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="692.5" y="573" width="380" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="xcorr" value="&lt;b&gt;单个候选模型评分&lt;/b&gt;&lt;br&gt;12 台站 × 3 分量 × 2 窗口 = 72 项&lt;br&gt;逐项试探 Δt = -40…+40 s&lt;br&gt;取 obs 与 syn 的最大归一化互相关 CC_best" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFF1EA;strokeColor=#A64B2A;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="640" y="997" width="485" height="108" as="geometry"/>
                </mxCell>
                <mxCell id="mean" value="&lt;b&gt;等权平均得到模型总分&lt;/b&gt;&lt;br&gt;Mean_windowed_CC = 72 个 CC_best 等权平均&lt;br&gt;Mean_windowed_CC 越大越好&lt;br&gt;若写成误差：Misfit = 1 − Mean_windowed_CC" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFF1EA;strokeColor=#A64B2A;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="675" y="1126" width="415" height="99" as="geometry"/>
                </mxCell>
                <mxCell id="rank" value="&lt;b&gt;保存并排序&lt;/b&gt;&lt;br&gt;每行：参数组合 + 得分 + 中位时移&lt;br&gt;按 Mean_windowed_CC 降序" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EDEAF6;strokeColor=#6D5BA6;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="641" y="1350" width="322" height="93" as="geometry"/>
                </mxCell>
                <mxCell id="refine" value="&lt;b&gt;高分区评估&lt;/b&gt;&lt;br&gt;缩小参数范围、减小步长&lt;br&gt;重复：正演 → 滤波 → 分窗 → 评分" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#EDEAF6;strokeColor=#6D5BA6;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="1057" y="1288" width="300" height="112" as="geometry"/>
                </mxCell>
                <mxCell id="result" value="&lt;b&gt;最终解释&lt;/b&gt;&lt;br&gt;高分范围：&lt;br&gt;Depth ≈ 6 km&lt;br&gt;Strike ≈ 60-70°&lt;br&gt;Dip ≈ 50–70°&lt;br&gt;Rake ≈ -170到-150°，偏向-160°" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8F3F8;strokeColor=#1F6F8B;fontSize=14;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="1062" y="1463" width="290" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="note2" value="&lt;b&gt;说明&lt;/b&gt;&lt;br&gt;当前评分采用等权平均；未加入台站权重、方位角权重或信噪比权重。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFF7E6;strokeColor=#8A6F2A;fontSize=13;fontColor=#20242A;fontFamily=Microsoft YaHei;spacing=8;spacingTop=6;spacingBottom=6;dashed=0;" parent="1" vertex="1">
                    <mxGeometry x="67" y="1171" width="500" height="75" as="geometry"/>
                </mxCell>
